{
  "expo": {
    "name": "robotube",
    "slug": "robotube",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "robotube",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joshmux.robotube",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow Robotube to access your photos so you can upload videos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.joshmux.robotube"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/robotube-logo.png",
          "imageWidth": 320,
          "resizeMode": "contain",
          "backgroundColor": "#b9b9b9",
          "dark": {
            "backgroundColor": "#b9b9b9"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Robotube to access your photos so you can upload videos."
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "de3c5ed0-6579-4e3d-a0be-c9042d696ecb"
      }
    },
    "owner": "muxcom"
  }
}
