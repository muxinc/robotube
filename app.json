{
  "expo": {
    "name": "robotube",
    "slug": "robotube",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "robotube",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "appleTeamId": "XX95P4Y787",
      "bundleIdentifier": "com.muxinc.robotube",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow Robotube to access your photos so you can upload videos.",
        "NSCameraUsageDescription": "Allow Robotube to use your camera for uploads and live streaming.",
        "NSMicrophoneUsageDescription": "Allow Robotube to use your microphone for uploads and live streaming."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/app-icon.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.joshmux.robotube"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/robotube-logo.png",
          "imageWidth": 320,
          "resizeMode": "contain",
          "backgroundColor": "#b9b9b9",
          "dark": {
            "backgroundColor": "#b9b9b9"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Robotube to access your photos so you can upload videos.",
          "cameraPermission": "Allow Robotube to use your camera for uploads and live streaming.",
          "microphonePermission": "Allow Robotube to use your microphone for uploads and live streaming."
        }
      ],
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc",
      "expo-secure-store",
      "expo-video",
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "de3c5ed0-6579-4e3d-a0be-c9042d696ecb"
      }
    },
    "owner": "muxcom"
  }
}
